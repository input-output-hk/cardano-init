# OS
.DS_Store
Thumbs.db

=== .env ===
# snap-project — environment configuration
# Generated by cardano-init. Edit freely.

CARDANO_NETWORK=mainnet

# Infrastructure connection details.
# Populated by the infrastructure component's `just dev`; left empty otherwise
# so consumers always find the keys at a stable, predictable location.
INDEXER_URL=
INDEXER_PORT=
NODE_SOCKET_PATH=

=== infra/yaci/Justfile ===
# Infrastructure component (Yaci DevKit) — PLACEHOLDER
# Part of snap-project
#
# This component lives at infra/yaci/, so the project root is two levels up (../../).

build:
    @echo "Yaci DevKit needs no build step."

test:
    @echo "Yaci DevKit has no tests."

# Bring up the local node + indexer, then write connection details to the
# project .env (two levels up: infra/<tool>/ -> project root).
dev:
    @echo "Yaci DevKit is a placeholder — not yet implemented."
    @echo "When implemented, this starts a local node + indexer and writes"
    @echo "INDEXER_URL / INDEXER_PORT / NODE_SOCKET_PATH into ../../.env."

clean:
    @echo "Nothing to clean (Yaci DevKit placeholder)."

