=== .env ===
# snap-project — environment configuration
# Generated by cardano-init. Edit freely.

CARDANO_NETWORK=preview

# Infrastructure connection details.
# Populated by the infrastructure component's `just dev`; left empty otherwise
# so consumers always find the keys at a stable, predictable location.
INDEXER_URL=
INDEXER_PORT=
NODE_SOCKET_PATH=

=== blueprint/.gitkeep ===

=== on-chain/aiken.toml ===
name = "snap-project/on-chain"
version = "0.0.0"
license = "Apache-2.0"
description = "On-chain validators for snap-project"

[repository]
user = "snap-project"
project = "on-chain"
platform = "github"

[[dependencies]]
name = "aiken-lang/stdlib"
version = "v2"
source = "github"

=== on-chain/Justfile ===
# On-chain component (Aiken)
# Part of snap-project

build:
    aiken build
    cp -f plutus.json ../blueprint/plutus.json

test:
    aiken check

dev:
    @echo "Aiken does not have a watch mode. Run 'just build' after changes."

clean:
    rm -rf build/
    rm -f plutus.json

=== on-chain/validators/example.ak ===
/// A simple always-succeeds validator.
/// Replace this with your own validator logic.
validator example {
  spend(_datum: Option<Data>, _redeemer: Data, _output_ref: Data, _tx: Data) {
    True
  }
}

