=== .env ===
# snap-project — environment configuration
# Generated by cardano-init. Edit freely.

CARDANO_NETWORK=preprod

# Chain connection details.
# Populated by whichever component provisions a local endpoint during its
# `just dev` — an infrastructure service, or a local devnet such as Yaci DevKit
# in the devnet role. Left empty otherwise, so consumers always find the keys
# at a stable, predictable location and degrade gracefully when they're blank.
INDEXER_URL=
INDEXER_PORT=
NODE_SOCKET_PATH=
# Endpoints populated when the matching infrastructure provider is provisioned.
OGMIOS_URL=
TX_SUBMIT_URL=
DOLOS_GRPC_URL=
CARDANO_NODE_API_URL=

=== infra/Justfile ===
# Infrastructure component (cardano-up) — provisions a local Cardano stack.
# Part of snap-project.
#
# This component lives at infra/, so the project root is one level up (../).
#
# The providers you selected with --infra are brought up together as a single
# cardano-up context named "snap-project":
#   - Kupo (kupo)
#   - Ogmios (ogmios)
#
# Requires Docker running and `cardano-up` on your PATH (see `cardano-init
# doctor`). The `-c/--context` flag targets this project's stack without
# touching your global active cardano-up context, so multiple projects coexist.

# Infrastructure is a runtime stack — there is nothing to build.
build:
    @echo "Nothing to build — infrastructure is a runtime stack. Run 'just dev' to provision it."

# Nothing to test without a running stack; kept as a no-op so the top-level
# `just test` stays green in CI (which has no Docker / running services).
test:
    @echo "Nothing to test — run 'just dev' to provision the stack."

# Provision the stack and publish its connection details to ../.env.
# Long-running: cardano-up brings up the Docker services for the context.
dev:
    cardano-up context create snap-project -n preprod 2>/dev/null || true
    cardano-up install kupo --context snap-project
    cardano-up install ogmios --context snap-project
    cardano-up up --context snap-project
    sh scripts/write-env.sh
    @echo "Stack 'snap-project' is up. Connection details written to ../.env."

# Stop the stack's containers. Chain data is preserved (no re-sync next time);
# for a full teardown run `cardano-up uninstall <pkg> --context snap-project`.
clean:
    cardano-up down --context snap-project
    @echo "Stopped the 'snap-project' stack."

=== infra/README.md ===
# Infrastructure (snap-project)

This component provisions a local Cardano infrastructure stack using
[`cardano-up`](https://github.com/blinklabs-io/cardano-up). The providers you
selected are managed together as a single cardano-up **context** named
`snap-project` (network: `preprod`):

- **Kupo** — cardano-up package `kupo`
- **Ogmios** — cardano-up package `ogmios`

## Prerequisites

- **Docker** running.
- **`cardano-up`** on your `PATH` — run `cardano-init doctor` for install help.

## Usage

```sh
just -f infra/Justfile dev      # provision the stack and write ../.env (long-running)
just -f infra/Justfile clean    # stop the stack (chain data is preserved)
```

`dev` creates/uses the `snap-project` context, installs the
providers (cardano-up resolves dependencies such as `cardano-node`
automatically), brings the Docker services up, and writes the connection
details into the project's `../.env`. Off-chain components read those values
(`INDEXER_URL`, `OGMIOS_URL`, `NODE_SOCKET_PATH`, …) and connect automatically.

The `-c/--context` flag scopes every command to this project's stack, so it
never disturbs your global active cardano-up context or other projects.

## Notes

- This component aggregates **all** `--infra` providers into one stack; there is
  no per-provider subdirectory.
- `cardano-up`'s state is machine-global (under `~/.config/cardano-up` and
  `~/.local/share/cardano-up`), not stored in this repo. The Justfile here is
  just a thin, project-scoped driver over it.

=== infra/scripts/write-env.sh ===
#!/usr/bin/env sh
# write-env.sh — translate cardano-up's context outputs into the project .env.
# Generated by cardano-init for snap-project.
#
# Run from infra/ (the dev recipe does this). It loads the cardano-up outputs
# for this project's context, then UPDATES the connection keys this stack owns
# in ../.env while preserving every other line — so keys seeded empty (e.g. an
# OGMIOS_URL on a kupo-only stack) stay present rather than being dropped.
set -e

CONTEXT="snap-project"
ENV_FILE="../.env"

# Load cardano-up's outputs (e.g. KUPO_URL, OGMIOS_URL, CARDANO_NODE_SOCKET_PATH)
# as shell variables. `context env` emits `export KEY=VALUE` lines.
eval "$(cardano-up context env --context "$CONTEXT")"

# Replace NAME=… in $ENV_FILE (append if absent); leaves all other lines intact.
set_key() {
    name="$1"
    value="$2"
    tmp="$(mktemp)"
    grep -v "^${name}=" "$ENV_FILE" > "$tmp" 2>/dev/null || true
    printf '%s=%s\n' "$name" "$value" >> "$tmp"
    mv "$tmp" "$ENV_FILE"
}

set_key CARDANO_NETWORK "preprod"
set_key NODE_SOCKET_PATH "$CARDANO_NODE_SOCKET_PATH"
set_key INDEXER_URL "$KUPO_URL"
set_key OGMIOS_URL "$OGMIOS_URL"

