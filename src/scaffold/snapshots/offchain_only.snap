=== .env ===
# snap-project — environment configuration
# Generated by cardano-init. Edit freely.

CARDANO_NETWORK=preview

# Infrastructure connection details.
# Populated by the infrastructure component's `just dev`; left empty otherwise
# so consumers always find the keys at a stable, predictable location.
INDEXER_URL=
INDEXER_PORT=
NODE_SOCKET_PATH=

