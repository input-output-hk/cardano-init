# {{ project_name }} — Cardano protocol project
# Generated by cardano-init. Edit freely.

default:
    @just --list
{%- if has_on_chain %}

# --- On-chain ({{ on_chain.tool_name }}) ---
build-on-chain:
    just -f {{ on_chain.dir }}/Justfile build

test-on-chain:
    just -f {{ on_chain.dir }}/Justfile test
{%- endif %}
{%- if has_off_chain %}

# --- Off-chain ({{ off_chain.tool_name }}) ---
build-off-chain:
    just -f {{ off_chain.dir }}/Justfile build

test-off-chain:
    just -f {{ off_chain.dir }}/Justfile test
{%- endif %}
{%- if has_infra %}

# --- Infrastructure ---
{%- for infra_tool in infra_tools %}
dev-{{ infra_tool.tool_id }}:
    just -f {{ infra_tool.dir }}/{{ infra_tool.tool_id }}/Justfile dev
{%- endfor %}
{%- endif %}
{%- if has_testing %}

# --- Testing ({{ testing.tool_name }}) ---
test-integration:
    just -f {{ testing.dir }}/Justfile test
{%- endif %}
{%- if has_formal_methods %}

# --- Formal methods ({{ formal_methods.tool_name }}) ---
verify:
    just -f {{ formal_methods.dir }}/Justfile test
{%- endif %}

# --- Aggregate tasks ---
build:
{%- if has_on_chain %} build-on-chain{% endif %}
{%- if has_off_chain %} build-off-chain{% endif %}
    @echo "Build complete."

test:
{%- if has_on_chain %} test-on-chain{% endif %}
{%- if has_off_chain %} test-off-chain{% endif %}
{%- if has_testing %} test-integration{% endif %}
{%- if has_formal_methods %} verify{% endif %}
    @echo "All tests passed."

clean:
{%- if has_on_chain %}
    just -f {{ on_chain.dir }}/Justfile clean
{%- endif %}
{%- if has_off_chain %}
    just -f {{ off_chain.dir }}/Justfile clean
{%- endif %}
{%- if has_testing %}
    just -f {{ testing.dir }}/Justfile clean
{%- endif %}
{%- if has_formal_methods %}
    just -f {{ formal_methods.dir }}/Justfile clean
{%- endif %}
    rm -f {{ blueprint_path }}
    @echo "Clean complete."

# --- dev: bring up the shared, long-running infrastructure ---
# Per-component watch/dev (on-chain, off-chain, testing, formal-methods) is run
# directly in each component dir; only infrastructure is orchestrated here.
{%- if not has_infra %}
dev:
    @echo "No infrastructure to start. Run a component's dev directly:"
{%- if has_on_chain %}
    @echo "  just -f {{ on_chain.dir }}/Justfile dev"
{%- endif %}
{%- if has_off_chain %}
    @echo "  just -f {{ off_chain.dir }}/Justfile dev"
{%- endif %}
{%- if has_testing %}
    @echo "  just -f {{ testing.dir }}/Justfile dev"
{%- endif %}
{%- if has_formal_methods %}
    @echo "  just -f {{ formal_methods.dir }}/Justfile dev"
{%- endif %}
{%- elif infra_tools | length == 1 %}
dev:
    just -f {{ infra_tools[0].dir }}/{{ infra_tools[0].tool_id }}/Justfile dev
{%- else %}
dev:
    @echo "Multiple infrastructure services selected. Start each in its own terminal:"
{%- for infra_tool in infra_tools %}
    @echo "  just dev-{{ infra_tool.tool_id }}"
{%- endfor %}
    @echo "Or install process-compose to orchestrate them together:"
    @echo "  https://f1bonacc1.github.io/process-compose/"
{%- endif %}
