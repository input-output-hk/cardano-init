# {{ project_name }} — Cardano protocol project
# Generated by cardano-init. Edit freely.
#
# The top level aggregates the tasks that terminate and compose: build, test,
# clean. Long-running / interactive tasks (watch modes, local devnets, REPLs)
# are per-component and optional — a component exposes `dev` only when it has
# such a mode. Run one directly, e.g. `just -f <dir>/Justfile dev`; list a
# component's targets with `just -f <dir>/Justfile --list`. See README.md.

default:
    @just --list
{%- if has_on_chain %}

# --- On-chain ({{ on_chain.tool_name }}) ---
build-on-chain:
    just -f {{ on_chain.dir }}/Justfile build

test-on-chain:
    just -f {{ on_chain.dir }}/Justfile test
{%- endif %}
{%- if has_off_chain %}

# --- Off-chain ({{ off_chain.tool_name }}) ---
build-off-chain:
    just -f {{ off_chain.dir }}/Justfile build

test-off-chain:
    just -f {{ off_chain.dir }}/Justfile test
{%- endif %}
{%- if has_testing %}

# --- Testing ({{ testing.tool_name }}) ---
test-integration:
    just -f {{ testing.dir }}/Justfile test
{%- endif %}
{%- if has_formal_methods %}

# --- Formal methods ({{ formal_methods.tool_name }}) ---
verify:
    just -f {{ formal_methods.dir }}/Justfile test
{%- endif %}

# --- Aggregate tasks ---
build:
{%- if has_on_chain %} build-on-chain{% endif %}
{%- if has_off_chain %} build-off-chain{% endif %}
    @echo '{{ "{{BOLD + GREEN}}✓ Build complete{{NORMAL}}" }}'

# Build the on-chain blueprint first (consumers read ../blueprint/plutus.json),
# then run each component's tests in role order.
test:
{%- if has_on_chain %} build-on-chain test-on-chain{% endif %}
{%- if has_off_chain %} test-off-chain{% endif %}
{%- if has_testing %} test-integration{% endif %}
{%- if has_formal_methods %} verify{% endif %}
    @echo '{{ "{{BOLD + BLACK + BG_GREEN}}  ✓  All tests passed  {{NORMAL}}" }}'

clean:
{%- if has_on_chain %}
    just -f {{ on_chain.dir }}/Justfile clean
{%- endif %}
{%- if has_off_chain %}
    just -f {{ off_chain.dir }}/Justfile clean
{%- endif %}
{%- if has_testing %}
    just -f {{ testing.dir }}/Justfile clean
{%- endif %}
{%- if has_formal_methods %}
    just -f {{ formal_methods.dir }}/Justfile clean
{%- endif %}
    rm -f {{ blueprint_path }}
    @echo '{{ "{{BOLD + GREEN}}✓ Clean complete{{NORMAL}}" }}'
