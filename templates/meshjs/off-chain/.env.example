# Off-chain secrets for submitting real transactions.
# Copy this file to `.env.local` (gitignored) and fill in the values.
# CARDANO_NETWORK is read from the shared ../.env.

# Blockfrost project id for your target network — https://blockfrost.io
BLOCKFROST_PROJECT_ID=

# Mnemonic (space-separated words) of the wallet that funds and signs txs.
# Use a throwaway test wallet — never commit a real seed phrase.
MNEMONIC=
