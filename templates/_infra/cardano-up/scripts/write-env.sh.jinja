#!/usr/bin/env sh
# write-env.sh — translate cardano-up's context outputs into the project .env.
# Generated by cardano-init for {{ project_name }}.
#
# Run from infra/ (the dev recipe does this). It loads the cardano-up outputs
# for this project's context, then UPDATES the connection keys this stack owns
# in ../.env while preserving every other line — so keys seeded empty (e.g. an
# OGMIOS_URL on a kupo-only stack) stay present rather than being dropped.
set -e

CONTEXT="{{ infra_context_name }}"
ENV_FILE="../.env"

# Load cardano-up's outputs (e.g. KUPO_URL, OGMIOS_URL, CARDANO_NODE_SOCKET_PATH)
# as shell variables. `context env` emits `export KEY=VALUE` lines.
eval "$(cardano-up context env --context "$CONTEXT")"

# Replace NAME=… in $ENV_FILE (append if absent); leaves all other lines intact.
set_key() {
    name="$1"
    value="$2"
    tmp="$(mktemp)"
    grep -v "^${name}=" "$ENV_FILE" > "$tmp" 2>/dev/null || true
    printf '%s=%s\n' "$name" "$value" >> "$tmp"
    mv "$tmp" "$ENV_FILE"
}

set_key CARDANO_NETWORK "{{ network }}"
{%- for m in infra_env %}
set_key {{ m.to }} "${{ m.from }}"
{%- endfor %}
